# Grow by XCADO — environment variables
# Copy this to .env.local for local dev, or set in the Vercel dashboard for prod.

VITE_APP_NAME=Grow by XCADO
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=preview

# When using the mock API (default in this preview build), leave blank.
# Set to a real PHP / Node API URL when wiring up the backend.
VITE_API_BASE_URL=

# Toggle: "true" forces the mock API layer; "false" calls VITE_API_BASE_URL.
VITE_USE_MOCK_API=true

VITE_TRACE_BASE_URL=https://grow.xcado.africa/trace

VITE_MPESA_CONSUMER_KEY=
VITE_OPENWEATHER_KEY=
VITE_GOOGL